# ============================================================
# GROUP PHOEBE — Variables d'environnement
# Copier vers .env.local et remplir avec les valeurs réelles
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Google OAuth (configurer dans Supabase Dashboard > Auth > Providers > Google) ---
# Ces variables sont gérées côté Supabase Dashboard, pas dans l'app.
# 1. Créer un projet Google Cloud > APIs & Services > Credentials > OAuth 2.0 Client
# 2. Authorized redirect URI : https://<project-ref>.supabase.co/auth/v1/callback
# 3. Copier Client ID et Client Secret dans Supabase Dashboard > Auth > Providers > Google

# --- CinetPay (Orange Money, MTN Money, Wave, cartes locales) ---
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=
CINETPAY_WEBHOOK_SECRET=

# --- Stripe (cartes internationales) ---
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Twilio (WhatsApp Business API + SMS) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# --- Resend (email transactionnel) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Mapbox (cartes, géolocalisation) ---
NEXT_PUBLIC_MAPBOX_TOKEN=

# ============================================================
# ENVIRONNEMENT DE TEST / CI
# ============================================================
#
# --- Stripe (mode test) ---
# Utiliser les clés de test Stripe (préfixe sk_test_ / pk_test_).
# Obtenir sur : https://dashboard.stripe.com/test/apikeys
# Cartes de test : 4242 4242 4242 4242 (succès), 4000 0000 0000 0002 (refus)
# Doc : https://docs.stripe.com/testing
#
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_test_...
#   → Pour le webhook local : stripe listen --forward-to localhost:3000/api/webhooks/stripe
#
# --- CinetPay (mode sandbox) ---
# Utiliser les identifiants sandbox CinetPay.
# Obtenir sur : https://app.cinetpay.com (section Sandbox)
# Doc : https://docs.cinetpay.com/api/sandbox
#
# CINETPAY_API_KEY=<sandbox api key>
# CINETPAY_SITE_ID=<sandbox site id>
# CINETPAY_SECRET_KEY=<sandbox secret>
#
# --- Supabase Auth (mode test) ---
# En local (supabase start), les OTP ne sont pas envoyés par SMS.
# Les OTP apparaissent dans les logs : supabase inspect db logs
# Ou utiliser l'API admin pour confirmer directement le téléphone :
#   supabase.auth.admin.updateUserById(userId, { phone_confirm: true })
#
# Pour le CI, utiliser les clés du projet Supabase local :
# NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase local anon key>
# SUPABASE_SERVICE_ROLE_KEY=<supabase local service role key>

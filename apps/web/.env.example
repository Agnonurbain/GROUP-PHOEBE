# ============================================================
# GROUP PHOEBE — Variables d'environnement
# Copier vers .env.local et remplir avec les valeurs réelles
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- CinetPay (Orange Money, MTN Money, Wave, cartes locales) ---
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=
CINETPAY_WEBHOOK_SECRET=

# --- Stripe (cartes internationales) ---
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Twilio (WhatsApp Business API + SMS) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# --- Resend (email transactionnel) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Mapbox (cartes, géolocalisation) ---
NEXT_PUBLIC_MAPBOX_TOKEN=
